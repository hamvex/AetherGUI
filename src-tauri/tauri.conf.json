{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "Firstham AetherGui",
    "version":  "1.5.0",
    "identifier":  "io.github.hamvex.aether-gui",
    "build":  {
                  "frontendDist":  "../dist",
                  "devUrl":  "http://localhost:1420",
                  "beforeDevCommand":  "node scripts/dev-server.mjs",
                  "beforeBuildCommand":  "node scripts/build-frontend.mjs \u0026\u0026 node scripts/prepare-sidecar.mjs"
              },
    "app":  {
                "windows":  [
                                {
                                    "label":  "main",
                                    "title":  "Firstham AetherGui",
                                    "width":  1100,
                                    "height":  740,
                                    "minWidth":  820,
                                    "minHeight":  620,
                                    "center":  true,
                                    "resizable":  true
                                }
                            ],
                "security":  {
                                 "csp":  "default-src \u0027self\u0027; style-src \u0027self\u0027 \u0027unsafe-inline\u0027; script-src \u0027self\u0027"
                             },
                "withGlobalTauri":  true
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "nsis",
                                   "msi"
                               ],
                   "publisher":  "hamvex",
                   "category":  "Utility",
                   "shortDescription":  "Firstham AetherGui — a standalone Windows client for Aether",
                   "longDescription":  "Connect Windows through Aether with built-in TUN routing, DNS protection, recovery, and no companion proxy application.",
                   "externalBin":  [
                                       "binaries/aether",
                                       "binaries/sing-box"
                                   ],
                   "resources": ["../third-party/sing-box-LICENSE.txt"],
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/icon.ico"
                            ],
                   "windows":  {
                                   "webviewInstallMode":  {
                                                              "type":  "embedBootstrapper"
                                                          },
                                   "nsis":  {
                                                "displayLanguageSelector":  true,
                                                "installMode":  "currentUser",
                                                "installerHooks":  "./windows/hooks.nsh"
                                            },
                                   "wix":  {
                                               "language":  "en-US"
                                           }
                               }
               }
}
